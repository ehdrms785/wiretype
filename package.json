{
  "name": "wiretype",
  "version": "0.1.0",
  "description": "Record real API traffic and generate TypeScript types, zod schemas, MSW mocks, and OpenAPI 3.1 specs — from what your backend actually returns.",
  "keywords": [
    "typescript",
    "codegen",
    "type-generation",
    "zod",
    "msw",
    "openapi",
    "api",
    "http-proxy",
    "recorder",
    "mock",
    "vite-plugin",
    "schema-inference"
  ],
  "license": "MIT",
  "author": "daro <donggeunhong@vgen.co.kr> (https://github.com/ehdrms785)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ehdrms785/wiretype.git"
  },
  "homepage": "https://github.com/ehdrms785/wiretype#readme",
  "bugs": "https://github.com/ehdrms785/wiretype/issues",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "wiretype": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    }
  },
  "files": [
    "dist",
    "viewer",
    "README.md",
    "README.ko.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "demo:api": "node examples/demo-api/server.mjs",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.1.0",
    "tsx": "^4.19.0",
    "vite": "^6.0.0",
    "zod": "^3.24.0",
    "msw": "^2.6.0"
  }
}
